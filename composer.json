{
    "name": "jeroendn/jeroendn-website",
    "description": "My personal website",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "ext-curl": "^8.0",
        "ext-pdo": "*",
        "laravel/framework": "^11.0",
        "laravel/tinker": "^2.10",
        "laravel/ui": "^4.6",
        "guzzlehttp/guzzle": "^7.9",
        "jeroendn/php-helpers": "0.7-beta",
        "jeroendn/php-js-console-logger": "^1.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.24.0",
        "nunomaduro/collision": "^8.5",
        "phpunit/phpunit": "^10.0",
        "spatie/laravel-ignition": "^2.9"
    },
    "config": {
        "optimize-autoloader": true,
        "policy": {
            "advisories": {
                "ignore-id": {
                    "PKSA-m5cs-t1y6-qpcs": "Laravel 11 is EOL; upgrade to Laravel 12 pending",
                    "PKSA-3r5d-mb8f-1qw9": "Laravel 11 is EOL; upgrade to Laravel 12 pending",
                    "PKSA-mdq4-51ck-6kdq": "Laravel 11 is EOL; upgrade to Laravel 12 pending",
                    "PKSA-8qx3-n5y5-vvnd": "Laravel 11 is EOL; upgrade to Laravel 12 pending",
                    "PKSA-q46n-4fdk-zjr4": "Laravel 11 is EOL; upgrade to Laravel 12 pending",
                    "PKSA-qzrn-rnz3-85w1": "Laravel 11 is EOL; upgrade to Laravel 12 pending",
                    "PKSA-w7xr-vk7n-rstm": "Laravel 11 is EOL; upgrade to Laravel 12 pending"
                }
            }
        },
        "preferred-install": "dist",
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        },
        "classmap": [
            "database/seeds",
            "database/factories"
        ],
        "files": [
            "app/Helper/Helper.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    }
}
